# Database Configuration
DATABASE_URL=postgresql://quantivara_user:quantivara_pass@localhost:5432/quantivara_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quantivara_db
DB_USER=quantivara_user
DB_PASSWORD=quantivara_pass

# Server Configuration
PORT=3001
NODE_ENV=development
API_VERSION=v1

# JWT Configuration
JWT_SECRET=quantivara-demo-jwt-secret-key-2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS Configuration
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# File Storage Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# AI/Mock Processing Configuration
PROCESSING_DELAY_MIN=10000
PROCESSING_DELAY_MAX=30000
AI_ACCURACY_MIN=89
AI_ACCURACY_MAX=98

# Demo Configuration
DEMO_MODE=true
DEMO_DATA_RESET_INTERVAL=86400000

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Healthcare Specific Configuration
ABHA_ID_LENGTH=14
SUPPORTED_LANGUAGES=en,hi
DEFAULT_TIMEZONE=Asia/Kolkata

# Revenue Tracking Configuration
LAB_MONTHLY_FEE=7000
HOSPITAL_MONTHLY_FEE=100000
PER_REPORT_FEE_LAB=50
PER_REPORT_FEE_HOSPITAL=100